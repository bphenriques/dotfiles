<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#c2660c" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#ffe57f" media="(prefers-color-scheme: dark)" />
    <meta
      name="description"
      content="Technical lead and software engineer, enthusiastic about self-hosting and NixOS."
    />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Bruno Henriques" />
    <meta
      property="og:description"
      content="Technical lead and software engineer, enthusiastic about self-hosting and NixOS."
    />
    <meta property="og:url" content="https://bphenriques.com/" />
    <meta property="og:image" content="https://bphenriques.com/avatar.jpg" />
    <meta property="og:image:width" content="460" />
    <meta property="og:image:height" content="460" />
    <meta name="twitter:card" content="summary" />
    <link rel="canonical" href="https://bphenriques.com/" />
    <title>Bruno Henriques</title>
    <link
      rel="icon"
      href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>👋</text></svg>"
    />
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <main>
      <h1>Bruno Henriques</h1>
      <p class="tagline">
        Technical lead and software engineer, enthusiastic about
        <a href="https://github.com/bphenriques/dotfiles">self-hosting</a> and
        NixOS.
      </p>
      <nav class="links" aria-label="profile links">
        <a href="https://github.com/bphenriques">GitHub</a>
        <a href="https://www.linkedin.com/in/bphenriques">LinkedIn</a>
        <a
          href="https://github.com/bphenriques/curriculum-vitae/releases/latest/download/bruno-henriques-cv.pdf"
          >cv.pdf</a
        >
      </nav>
      <details class="homelab">
        <summary>{{hostCount}} hosts · {{serviceCount}} services</summary>
        <dl class="svc">
          {{#categories}}
          <dt>{{name}}</dt>
          {{#services}}
          <dd>{{#homepage}}<a href="{{homepage}}" target="_blank" rel="noopener">{{displayName}}</a>{{/homepage}}{{^homepage}}{{displayName}}{{/homepage}}</dd>
          {{/services}}
          {{/categories}}
        </dl>
        {{#hasMore}}<p class="more">...and {{moreCount}} more</p>{{/hasMore}}
      </details>
      <p class="hint">
        psst: <code>curl -sI</code> this page.
      </p>
    </main>
  </body>
</html>
